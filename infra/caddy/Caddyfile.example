{
	email you@example.com
}

duckermind.com, www.duckermind.com {
	root * /var/www/duckermind.com
	file_server
	encode zstd gzip
}

agora.duckermind.com {
	redir https://duckermind.com/projects/agora/ 308
}

noesis.duckermind.com {
	redir https://duckermind.com/projects/noesis/ 308
}

peras.duckermind.com {
	redir https://duckermind.com/projects/peras/ 308
}

physis.duckermind.com {
	redir https://duckermind.com/projects/physis/ 308
}

titan.duckermind.com {
	redir https://duckermind.com/projects/titan/ 308
}

